# Build artifacts (1.2 GB)
/target/

# Local development overrides (breaks fresh clones)
# Pattern `config.toml*` also catches `.dev-aside` etc. used during cross-repo
# refactors that temporarily move the config aside.
.cargo/config.toml*

# Python bytecode (produced by scripts/compare_monthly.py and friends)
__pycache__/
*.pyc

# OS files
.DS_Store
**/.DS_Store

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Log files (reproducible profiler output)
*.log

# Default output directories (not the committed output_*_full/ artifacts)
/profiler_output/
/test_output/
/test_output_full/
